      "calculations": [
        {
          "name": "bi78",
          "label": "Marketing Pct of Sales",
          "type": "AggregateCalculatedItem",
          "xref": "",
          "expression": "div(aggregate(average,group,${bi25,raw}),aggregate(sum,group,${bi36,raw}))"
        },
        {
          "name": "bi381",
          "label": "Adjusted Sales",
          "type": "CalculatedItem",
          "xref": "",
          "expression": "cond(in(${bi31,binned},'US_MW','US_CS','US_AT','LATA','EU','ASIA'),times(${bi36,raw},plus(0.85,#{pr380})),times(${bi36,raw},plus(1,#{pr380})))"
        },
        {
          "name": "bi383",
          "label": "Sales per SQFT",
          "type": "AggregateCalculatedItem",
          "xref": "",
          "expression": "div(aggregate(sum,group,${bi36,raw}),aggregate(average,group,${bi45,raw}))"
        },
        {
          "name": "bi477",
          "label": "ROI",
          "type": "AggregateCalculatedItem",
          "xref": "",
          "expression": "div(minus(aggregate(sum,group,${bi36,raw}),aggregate(sum,group,${bi37,raw})),aggregate(sum,group,${bi37,raw}))"
        },
        {
          "name": "bi478",
          "label": "Adjusted Sales Cost",
          "type": "CalculatedItem",
          "xref": "",
          "expression": "times(${bi37,raw},plus(1,#{pr424}))"
        },
        {
          "name": "bi479",
          "label": "Adjust ROI",
          "type": "AggregateCalculatedItem",
          "xref": "",
          "expression": "div(minus(aggregate(sum,group,${bi381,raw}),aggregate(sum,group,${bi478,raw})),aggregate(sum,group,${bi478,raw}))"
        }
